<!DOCTYPE html>
<html>
<head>
    <title>Styled Login Form</title>

    <style>
        body{
            font-family: Arial;
            background-color: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .login-box{
            background: white;
            padding: 30px;
            width: 300px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        h2{
            text-align: center;
            margin-bottom: 20px;
        }

        input{
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: 1px solid gray;
            border-radius: 5px;
        }

        button{
            width: 100%;
            padding: 10px;
            background-color: blue;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover{
            background-color: darkblue;
        }
    </style>
</head>

<body>

    <div class="login-box">
        <h2>Login Form</h2>

        <form>
            <label>Username</label>
            <input type="text" placeholder="Enter username">

            <label>Password</label>
            <input type="password" placeholder="Enter password">

            <button type="submit">Login</button>
        </form>
    </div>

</body>
</html>
